# ── TWC CLI environment template ─────────────────────────────────────────────
# Copy to `.env` (project root) or `~/.twc/.env` (works for global installs).
# Process-level env vars always override values defined here.

# Foundry Local OpenAI-compatible endpoint. Leave this UNSET (commented out) so
# the CLI auto-discovers it via `foundry service status` — the service picks a
# new dynamic port on each restart, so a hardcoded port goes stale. Only set it
# to pin a fixed loopback address.
# FOUNDRY_LOCAL_ENDPOINT=http://127.0.0.1:5273/v1

# Default model id. Prefer persisting via `twc models use <id-or-alias>`, which
# takes priority over this value. See `twc models list`.
# NOTE: NPU/QNN builds can hang indefinitely on some Snapdragon hosts; the CPU
# build below is steady and fast (~2s/answer). Switch with `twc models use`.
FOUNDRY_LOCAL_MODEL=qwen2.5-0.5b-instruct-generic-cpu:4

# API key for the local endpoint. Foundry Local ignores it, but a real value
# silences the placeholder warning.
FOUNDRY_LOCAL_API_KEY=local-dev-key

# Optional: TeamViewer Management Console script/personal token. When set, the
# auth-policy specialist calls the TeamViewer Web API (/ping, /account, /devices).
# TEAMVIEWER_API_TOKEN=

# Optional: override the workflow timeout (ms). Default 120000.
# TWC_WORKFLOW_TIMEOUT_MS=120000

# Optional: portable data directory (jobs, logs, config, history).
# Default resolution: TWC_HOME > ./.twc-data (legacy) > ~/.twc
# TWC_HOME=

# Optional: disable ANSI colors in non-TTY or CI environments.
# NO_COLOR=1

# Leave MASTRA_AGENT_ENDPOINT unset — remote Mastra endpoints are disabled by design.
